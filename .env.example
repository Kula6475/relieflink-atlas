# Copy this file to .env (cp .env.example .env) and fill in what you need.
# .env is gitignored, never commit real keys.

# Only needed for real Claude vision calls (Nehal) and the Phase 2 explainer.
# Everyone else can leave it blank and use the --fake / --synthetic modes.
ANTHROPIC_API_KEY=

# Claude model used for vision counting and explanations.
CLAUDE_MODEL=claude-opus-4-8

# Where the ledger API is running.
LEDGER_URL=http://localhost:8000
